{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.damiancolo/banco-de-ideas-mcp",
  "description": "Read, publish and explore creative bisociations between concepts on unbancodeideas.com.",
  "websiteUrl": "https://unbancodeideas.com",
  "repository": {
    "url": "https://github.com/damiancolo/banco-de-ideas-mcp",
    "source": "github"
  },
  "version": "1.0.2",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "banco-de-ideas-mcp",
      "version": "1.0.2",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "BANCO_API_URL",
          "description": "Base URL of the Banco de Ideas API",
          "isRequired": false,
          "format": "string",
          "default": "https://unbancodeideas.com"
        }
      ]
    }
  ]
}
